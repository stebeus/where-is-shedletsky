{
	"name": "api",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"imports": {
		"#root/*": "./source/*"
	},
	"scripts": {
		"build": "tsc",
		"db:generate": "drizzle-kit migrate",
		"db:migrate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:seed": "node scripts/seed.ts",
		"db:studio": "drizzle-kit studio --port=3999 --verbose",
		"dev": "node --watch source/index.ts",
		"start": "node source/index.ts",
		"test": "vitest"
	},
	"dependencies": {
		"@hono/node-server": "^2.0.8",
		"@hono/standard-validator": "^0.2.3",
		"drizzle-orm": "1.0.0-beta.22",
		"hono": "^4.12.30",
		"postgres": "^3.4.9",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@repository/typescript-config": "workspace:*",
		"@types/node": "^26.1.1",
		"drizzle-kit": "1.0.0-beta.22"
	}
}
