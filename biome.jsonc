{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"complexity": {
				"preset": "all"
			},
			"correctness": {
				"noGlobalDirnameFilename": "on",
				"useImportExtensions": "on"
			},
			"style": {
				"noCommonJs": "on",
				"noExportedImports": "on",
				"noNegationElse": "on",
				"noNestedTernary": "on",
				"noParameterAssign": "on",
				"noSubstr": "on",
				"noUnusedTemplateLiteral": "on",
				"noUselessElse": "on",
				"noYodaExpression": "on",
				"useAtIndex": "on",
				"useCollapsedIf": "on",
				"useConsistentArrowReturn": "on",
				"useConsistentObjectDefinitions": "on",
				"useDefaultParameterLast": "on",
				"useDefaultSwitchClause": "on",
				"useDestructuring": "on",
				"useFilenamingConvention": "on",
				"useForOf": "on",
				"useNamingConvention": "on",
				"useNumericSeparators": "on",
				"useObjectSpread": "on",
				"useShorthandAssign": "on",
				"useSingleVarDeclarator": "on",
				"useThrowNewError": "on",
				"useTrimStartEnd": "on",
				"noRestrictedImports": {
					"level": "on",
					"options": {
						"patterns": [
							{
								"group": "../**/*",
								"message": "Avoid relative parent imports. Use `#root/` absolute paths instead."
							}
						]
					}
				}
			},
			"suspicious": {
				"noForIn": "on",
				"noImportCycles": "on",
				"noVar": "on",
				"useAwait": "on"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"useSortedPackageJson": "on",
				"organizeImports": {
					"level": "on",
					"options": {
						"sortBareImports": true,
						"groups": [
							{ "type": true },
							":BLANK_LINE:",
							":NODE:",
							":BLANK_LINE:",
							[":PACKAGE_WITH_PROTOCOL:", ":PACKAGE:", "!@repository/**"],
							":BLANK_LINE:",
							"@repository/**",
							":BLANK_LINE:",
							":ALIAS:",
							":BLANK_LINE:",
							{ "kind": "!bare" },
							":BLANK_LINE:",
							{ "kind": "bare" }
						]
					}
				}
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/libraries/**", "**/*.config.{js,ts}", "**/*.jsonc", "!**/biome.jsonc"],
			"assist": {
				"actions": {
					"source": {
						"useSortedKeys": {
							"level": "on",
							"options": {
								"groupByNesting": true
							}
						}
					}
				}
			}
		},
		{
			"includes": ["**/env.{js,ts}"],
			"linter": {
				"rules": {
					"style": {
						"useNamingConvention": {
							"level": "on",
							"options": {
								"conventions": [
									{
										"formats": ["CONSTANT_CASE"],
										"selector": {
											"kind": "objectLiteralProperty"
										}
									}
								]
							}
						}
					}
				}
			}
		}
	]
}
